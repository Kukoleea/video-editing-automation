{
  "project_name": "clip-automation",
  "paths": {
    "raw_materials": "materials/raw",
    "audio_materials": "materials/audio",
    "subtitle_materials": "materials/subtitles",
    "jobs": "jobs",
    "logs": "logs",
    "output_renders": "output/renders",
    "output_temp": "output/tmp"
  },
  "scan": {
    "raw_extensions": [
      ".mp4",
      ".mov",
      ".mkv",
      ".avi",
      ".mxf"
    ],
    "audio_extensions": [
      ".mp3",
      ".wav",
      ".m4a",
      ".aac",
      ".flac"
    ],
    "subtitle_extensions": [
      ".srt",
      ".ass",
      ".vtt",
      ".txt"
    ]
  },
  "render": {
    "ffmpeg_path": "",
    "target_resolution": "1920x1080",
    "target_fps": 30
  }
}
